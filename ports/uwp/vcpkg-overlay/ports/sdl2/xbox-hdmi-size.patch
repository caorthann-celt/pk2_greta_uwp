+extern "C" int
+D3D11_GetXboxHdmiDisplaySize(int *w, int *h)
+{
+    if (!w || !h) {
+        return 0;
+    }
+
+    try {
+        Platform::String ^ deviceFamily = AnalyticsInfo::VersionInfo->DeviceFamily;
+        if (!deviceFamily || wcscmp(deviceFamily->Data(), L"Windows.Xbox") != 0) {
+            return 0;
+        }
+
+        HdmiDisplayInformation ^ displayInformation = HdmiDisplayInformation::GetForCurrentView();
+        if (!displayInformation) {
+            return 0;
+        }
+
+        HdmiDisplayMode ^ displayMode = displayInformation->GetCurrentDisplayMode();
+        if (!displayMode) {
+            return 0;
+        }
+
+        int width = (int)displayMode->ResolutionWidthInRawPixels;
+        int height = (int)displayMode->ResolutionHeightInRawPixels;
+        if (width <= 0 || height <= 0) {
+            return 0;
+        }
+
+        *w = width;
+        *h = height;
+        return 1;
+    } catch (Platform::Exception ^) {
+        return 0;
+    }
+}
+
 #endif /* SDL_VIDEO_RENDER_D3D11 */
 
